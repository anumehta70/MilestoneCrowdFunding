# Copy this file to .env.local and fill in the values printed by
# scripts/deploy.sh (or the "Deploy Contracts" GitHub Action) after deploying.

# testnet | mainnet | futurenet
NEXT_PUBLIC_NETWORK=testnet

# Contract ID of the deployed Registry contract.
NEXT_PUBLIC_REGISTRY_CONTRACT_ID=

# Optional, only needed if you build a factory-style flow that deploys
# new Escrow contracts from the UI directly instead of via the CLI.
NEXT_PUBLIC_ESCROW_FACTORY_CONTRACT_ID=
